# ============================================================================
# MANTHANA LABS - REQUIRED ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your actual values
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE (Authentication + profiles in Postgres)
# ----------------------------------------------------------------------------
# Project URL: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Public client key: use either legacy anon key or newer publishable default key (not both required).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Service role: server-only (webhooks, admin). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth → URL configuration: add Site URL and Redirect URLs, e.g.
#   http://localhost:3001/**  and  https://your-domain.com/**
# Add explicit callback: http://localhost:3001/auth/callback  and  https://your-domain.com/auth/callback
# Google sign-in: Dashboard → Authentication → Providers → Google (Client ID + Secret from Google Cloud
#   Console → APIs & Services → Credentials → OAuth 2.0 Client). Authorized redirect URI in Google:
#   https://<YOUR_SUPABASE_PROJECT_REF>.supabase.co/auth/v1/callback
# Production: use HTTPS Site URL so auth cookies are secure; sessions persist until Log out (Settings) or clear site data.
#
# Auth email (pick one):
# A) Custom SMTP in Supabase Dashboard → Auth → use Amazon SES SMTP credentials.
# B) Send Email hook → HTTPS URL (reuses AWS SDK below, same as receipts):
#    Dashboard → Authentication → Hooks → Send Email
#    URL: https://<your-domain>/api/supabase/auth-send-email
#    Copy hook secret here:
# SUPABASE_SEND_EMAIL_HOOK_SECRET=v1,whsec_...

# ----------------------------------------------------------------------------
# AWS / AMAZON SES (Email) — receipts, non-auth mail, optional if all auth mail via Supabase SMTP
# ----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

NEXT_PUBLIC_APP_DOMAIN=manthana.quaasx108.com
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# RAZORPAY (Payments) - REQUIRED for subscriptions
# ----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Legacy Basic plan id (webhooks only — not shown in product UI)
RAZORPAY_PLAN_BASIC_ID=
RAZORPAY_PLAN_PRO_ID=
# Pro Plus — prefer this; if empty, RAZORPAY_PLAN_ENTERPRISE_ID is used for the same Razorpay plan
RAZORPAY_PLAN_PROPLUS_ID=
RAZORPAY_PLAN_ENTERPRISE_ID=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ----------------------------------------------------------------------------
# UI — slim product (Oracle + Labs + History/Settings) vs full nav
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_FULL_MANTHANA_NAV=1

# ----------------------------------------------------------------------------
# Product access (Oracle daily cap for free-tier users)
# ----------------------------------------------------------------------------
# Server-enforced when SUPABASE_SERVICE_ROLE_KEY is set and oracle quota columns exist (see supabase/migrations).
# FREE_ORACLE_DAILY_CAP=35

# ----------------------------------------------------------------------------
# BACKEND API URLs (for AI services)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
# Browser calls e.g. /api/oracle-backend/consent — proxied to ORACLE_INTERNAL_URL (server). If oracle is not running, consent returns HTTP 502; in NODE_ENV=development the Labs consent gate still lets you through (consent not stored).
# ORACLE_INTERNAL_URL=http://127.0.0.1:8100
# Optional dev: skip the consent POST entirely (still must tick the checkbox). Use if you hit non-502 errors locally.
# NEXT_PUBLIC_ANALYSE_DEV_BYPASS_CONSENT_GATEWAY=1
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ORACLE_API_URL=http://localhost:8100
NEXT_PUBLIC_WEB_API_URL=http://localhost:8200
NEXT_PUBLIC_RESEARCH_API_URL=http://localhost:8201
NEXT_PUBLIC_ANALYSIS_API_URL=http://localhost:8202
NEXT_PUBLIC_CLINICAL_API_URL=http://localhost:8203

# ----------------------------------------------------------------------------
# MANTHANA WEB (medical search UI) — feature flag
# ----------------------------------------------------------------------------
NEXT_PUBLIC_MANTHANA_WEB_LOCKED=true

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
# Subscriptions and billing live in Supabase Postgres (`public.profiles`).
# Apply SQL in supabase/migrations/ in the Supabase SQL editor or CLI.
#
# Optional: seed test users (create accounts in Auth first, then run in SQL editor):
#   update public.profiles set subscription_plan = 'free', subscription_status = 'inactive',
#     scans_limit = 10, scans_this_month = 0
#     where id = (select id from auth.users where email = 'shivakumarcjh@gmail.com');
#   update public.profiles set subscription_plan = 'pro', subscription_status = 'active',
#     scans_limit = 99999999, scans_this_month = 0
#     where id = (select id from auth.users where email = 'thamsa007@gmail.com');
# Migrate legacy plan name: update public.profiles set subscription_plan = 'proplus' where subscription_plan = 'enterprise';

# ----------------------------------------------------------------------------
# OPTIONAL / DEBUG / ADVANCED
# ----------------------------------------------------------------------------
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
