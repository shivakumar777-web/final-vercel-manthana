# Labs frontend — copy to .env.local
#
# Gateway URL for analyse (JWT from login — no OpenRouter keys in the browser).
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
#
# Orchestration rollout phase (A/B/C) — must align with gateway ORCH_ALLOWED_GROUPS.
NEXT_PUBLIC_ORCH_PHASE=A
#
# Feature flags
# NEXT_PUBLIC_AI_ORCHESTRATION_ENABLED=false
# NEXT_PUBLIC_AI_DYNAMIC_SECTIONS_ENABLED=false
# NEXT_PUBLIC_NIM_FEATURES_ENABLED=true
